# Optional runtime overrides (copy to .env)
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=1
USE_JS_BUNDLE=0
# OD_SKIP_PREP=1          # skip build/typecheck/pytest on start.bat
# OD_FULL_PREP=1          # include Playwright e2e in start prep
# RISK_FREE=0.037         # annualized risk-free rate for BSM/sim (default 0.037)
# SNAPSHOT_RETENTION_DAYS=180  # prune snapshots/alert_events older than this on startup (0 = keep)
# YF_RETRY_COUNT=3             # yfinance retries per call before giving up (default 3)
# YF_RETRY_BACKOFF=1.5         # initial retry wait in seconds; doubles each attempt (default 1.5)
# YF_RATE_LIMIT_PER_MIN=30     # max yfinance calls per minute across all endpoints (0 = unlimited)
# BG_REFRESH_INTERVAL_MIN=5    # background market-data refresh interval in minutes (0 = disabled)

# Schwab API (v1.2 — not wired yet; see docs/SCHWAB_API.md)
# SCHWAB_CLIENT_ID=
# SCHWAB_CLIENT_SECRET=
# SCHWAB_CALLBACK_URL=https://127.0.0.1:8182
# SCHWAB_TOKEN_PATH=./schwab_token.json
